# Firebase web config — copy this file to `.env` and fill in the values from
# the Firebase console: Project settings → General → Your apps → SDK setup.
# These are safe to expose in the client; access is controlled by
# firestore.rules. Leave them blank to run in local (localStorage) mode.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
